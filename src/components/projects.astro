---
const projects = [
  {
    title: "Flappy Birb",
    image: "https://raw.githubusercontent.com/jiayiwang00/-Flappy-Birb/main/bmp/image1.png",
    source: "https://github.com/jiayiwang00/-Flappy-Birb",
    preview: "https://jiayiwang00.github.io/-Flappy-Birb/",
    status: "Playable web game",
  },
];
---

<section id="projects" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Projects</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <article class="group">
          <a href={project.preview} target="_blank" rel="noopener noreferrer" class="block">
            <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 mb-4 bg-[#141414]">
              <img
                src={project.image}
                alt={`${project.title} gameplay`}
                class="w-full h-48 md:h-72 object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          </a>
          <div class="flex items-center px-3 gap-3">
            <div class="flex-grow">
              <h4 class="text-2xl font-semibold">{project.title}</h4>
              <span class="py-1 text-sm text-[var(--white-icon)]">{project.status}</span>
            </div>
            <a target="_blank" rel="noopener noreferrer" href={project.source} aria-label="View source on GitHub" class="size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition border border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7"><path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" /></svg>
            </a>
            <a target="_blank" rel="noopener noreferrer" href={project.preview} aria-label="Play Flappy Birb" class="size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition border border-[var(--white-icon-tr)] p-3 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7"><path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" /></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <a target="_blank" rel="noopener noreferrer" href="https://github.com/jiayiwang00?tab=repositories" class="w-full flex items-center justify-center gap-2 mt-9 text-[var(--white-icon)] hover:text-white transition border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:scale-105">
      <span class="md:text-lg text-md">More projects on GitHub</span>
    </a>
  </div>
</section>
