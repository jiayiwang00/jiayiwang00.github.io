---
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto text-center space-y-5">
    <div class="flex justify-center gap-5 text-[var(--white-icon)]">
      <a href="https://github.com/jiayiwang00" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--white)] transition-colors">GitHub</a>
      <a href="https://jiayiwang00.github.io/-Flappy-Birb/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--white)] transition-colors">Play Flappy Birb</a>
    </div>
    <p class="text-sm text-[var(--white-icon)]">
      Built with Astro and Tailwind CSS · Deployed on GitHub Pages
    </p>
    <p class="text-xs text-[var(--white-icon)] opacity-70">
      © {currentYear} Jiayi Wang · Template © <a class="underline hover:text-[var(--white)]" href="https://github.com/Gothsec">Oscar Hernandez</a>
    </p>
  </div>
</footer>
