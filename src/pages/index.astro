---
const links = [
  {
    label: "jiayiwang66@outlook.com",
    href: "mailto:jiayiwang66@outlook.com",
    external: false,
  },
  {
    label: "GitHub",
    href: "https://github.com/jiayiwang00",
    external: true,
  },
  {
    label: "Portfolio",
    href: "/portfolio/",
    external: false,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Jiayi Wang — software developer building thoughtful, interactive web experiences."
    />
    <meta name="theme-color" content="#f7f6f2" />
    <link rel="canonical" href="https://jiayiwang00.github.io/" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Jiayi Wang</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Software developer</p>
      <h1>Jiayi Wang</h1>
      <nav aria-label="Primary links">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: #f7f6f2;
  }

  :global(body) {
    min-height: 100svh;
    margin: 0;
    display: grid;
    place-items: center;
    padding: 2rem;
    color: #171714;
    background: #f7f6f2;
    font-family: Georgia, "Times New Roman", Times, serif;
    text-rendering: optimizeLegibility;
  }

  main {
    width: min(100%, 28rem);
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: #66645d;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.035em;
  }

  nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  a {
    position: relative;
    color: inherit;
    font-size: 1rem;
    line-height: 1.35;
    text-decoration: none;
  }

  a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 180ms ease;
  }

  a:hover::after,
  a:focus-visible::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  a:focus-visible {
    outline: 2px solid #171714;
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    a::after {
      transition: none;
    }
  }
</style>
